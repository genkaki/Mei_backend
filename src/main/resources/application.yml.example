server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/meistudio_db?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
    username: root
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver

  data:
    redis:
      host: localhost
      port: 6379

  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB

mybatis-plus:
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
    map-underscore-to-camel-case: true

# JWT Configuration
jwt:
  secret: YOUR_JWT_SECRET_KEY
  expiration: 604800000  # 7 days in milliseconds

# Knowledge Base Configuration
knowledge:
  chunk-size: 500
  chunk-overlap: 50
  search-top-k: 3

# DashScope Configuration (Unified Vector API Key)
dashscope:
  api-key: "YOUR_DASHSCOPE_API_KEY"

# Agent Configuration
agent:
  model-name: qwen3-omni-flash-2025-12-01
  max-search-results: 5
  memory-window-size: 50
  max-retry-attempts: 3
